# kdb+ connection for openbb-kdb. Copy to `.env` (git-ignored) and fill in.
#   cp .env.example .env
# These are read by the integration and the scripts; nothing here is committed.

KDB_HOST=localhost
KDB_PORT=5000
# KDB_USER=
# KDB_PASSWORD=

# The client connects in PyKX unlicensed (IPC) mode and needs NO KX license.
# A license is only for embedded/in-process q, which this package does not use.
# If you ever need one for other tooling, point to it here (kept out of git):
# QLIC=/path/to/dir/containing/kc.lic
# KDB_LICENSE_B64=<base64-license>
